RAILWAY_DOCKERFILE_PATH=apps/api/Dockerfile
RAILWAY_RUN_UID=0

PG_DUMP_BACKUP_ENABLED=true
PG_DUMP_BINARY=pg_dump
SYSTEM_BACKUP_PROVIDER=rclone_drive
RCLONE_BINARY=rclone
RCLONE_CONFIG_FILE=/data/rclone/rclone.conf
RCLONE_CONFIG_CONTENT_BASE64=
RCLONE_REMOTE=gdrive
SYSTEM_BACKUP_REMOTE_PATH=system-backups
