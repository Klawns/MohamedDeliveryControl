{
    "name": "@mdc/database",
    "version": "0.0.1",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "db:push": "node ./scripts/run-drizzle.cjs push",
        "db:generate": "node ./scripts/run-drizzle.cjs generate",
        "db:migrate": "node ./scripts/run-drizzle.cjs migrate",
        "db:migrate:postgres": "node ./scripts/run-drizzle.cjs migrate postgres",
        "db:generate:postgres": "node ./scripts/run-drizzle.cjs generate postgres",
        "db:studio": "node ./scripts/run-drizzle.cjs studio"
    },
    "dependencies": {
        "drizzle-orm": "latest",
        "pg": "^8.13.3"
    },
    "devDependencies": {
        "@types/node": "^22.13.9",
        "@types/pg": "^8.11.11",
        "dotenv": "^17.3.1",
        "drizzle-kit": "latest",
        "typescript": "5.7.3"
    }
}
